# 默认模型配置
DEFAULT_MODEL=qianwen

# 是否启用终端模型选择（可选，默认为 false）
# true: 启动时在终端让用户选择模型
# false: 直接使用默认模型，不弹出选择
ENABLE_TERMINAL_SELECTION=false

# ===== 智谱AI配置 =====
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ===== DeepSeek配置 =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===== 豆包配置（火山引擎）=====
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=doubao-pro-32k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ===== Kimi配置 =====
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ===== 千问配置（阿里云百炼 - 兼容模式）=====
QIANWEN_API_KEY=your_qianwen_api_key_here
QIANWEN_MODEL=qwen3.5-32b
QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 文心一言配置 =====
ERNIE_API_KEY=your_ernie_api_key_here
ERNIE_SECRET_KEY=your_ernie_secret_key_here
ERNIE_MODEL=ernie-4.0-turbo
ERNIE_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat

# ===== NVIDIA API配置 =====
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 服务器配置
PORT=5000

# 认证密码（SHA-256哈希值）
AUTH_PASSWORD_HASH=your_sha256_hash_here

# 讯飞语音识别配置
XFYUN_APPID=your_xfyun_appid_here
XFYUN_API_KEY=your_xfyun_api_key_here