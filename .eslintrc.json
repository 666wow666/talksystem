{
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "indent": ["error", 2],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "comma-dangle": ["error", "never"],
    "linebreak-style": ["error", "unix"],
    "no-trailing-spaces": "error",
    "eqeqeq": ["error", "always"],
    "no-eval": "error",
    "strict": ["error", "global"]
  }
}